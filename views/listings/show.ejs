<% layout("/layouts/boilerplate") %>

  
    <div class="row">
      <div class="col-lg-8 col-md-10 col-12 mx-auto mt-3">
        <h3>
          <%=listing.title %>
        </h3>
      </div>
      <!-- Image -->
      <div class="card listing-card show-card col-lg-8 col-md-10 col-12 mx-auto">
        <img src="<%= listing.image.url %>" class="card-img-top show-img">

        <div class="card-body">

          <p>
            Owned by:
            <b><i>
                <%= listing.owner.username %>
              </i></b>
          </p>

          <p>
            <%= listing.description %>
          </p>

          <p>&#8377; <%= listing.price.toLocaleString("en-IN") %>
          </p>

          <p>
            <%= listing.location %>
          </p>

          <p>
            <%= listing.country %>
          </p>

        </div>
      </div>
      <br /><br />

      <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="show-div offset-2">
          <div class="row-1">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark show-edit">Edit</a>
          </div>

          <div class="row-1">
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-dark show-delete mb-3">Delete</button>
            </form>
          </div>
        </div>
        <% } %>


    </div>

    <div class="col-8 offset-2 mb-3">
      <hr />
      <% if (currUser) { %>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

          <label for="rating" class="form-label">Rating</label>

          <div class="mb-1">
            <fieldset class="starability-coinFlip">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">
              Please submit some comments for review
            </div>
          </div>
          <button class="btn btn-outline-dark">Submit</button>
        </form>
        <hr>
        <% } %>



          <p><b>All Reviews</b></p>

          <div class="row">
            <% for( review of listing.reviews ) { %>
              <div class="card col-5 mb-3 ms-3">
                <div class="card-body">
                  <div class="card-title"> <b>@<%= review.author.username%></b></div>
                  <p class="starability-result card-text mb-2" data-rating="<%= review.rating %>">
                    <!-- Rated: 3 stars -->
                  </p>
                  <p class="card-text mb-3">
                    <%= review.comment %>
                  </p>


                </div>

                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-2 mt-1"
                  method="POST">
                  <button class="btn btn-sm btn-dark" style="color: white;">Delete</button>
                </form>

              </div>
              <% } %>
          </div>

          <div class="col-8 offset-2 mb-3">
            <h3>Where you'll be</h3>
           <div
  id="map"
  data-coordinates='<%- JSON.stringify(listing.geometry.coordinates) %>'
  data-location="<%= listing.location %>">
</div>
          </div>

    </div>
    <br>
   
