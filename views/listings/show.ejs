<% layout("/layouts/boilerplate") %>

<body>
  <div class="row">
    <div class="col-8 offset-2 mt-3">
      <h3><%=listing.title %></h3>
    </div>
    <div class="card listing-card col-6 offset-2" style="width: 18rem">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="..."
      />
      <div class="card-body">
        <p class="card-text">
          <b></b>
          <%=listing.description %> <br />
          &#8377; <%=listing.price.toLocaleString("en-IN")%> <br />
          <%=listing.location %> <br />
          <%=listing.country %>
        </p>
      </div>

      <br /><br />

      <div class="show-div">
        <div class="row-1">
          <a
            href="/listings/<%= listing._id %>/edit"
            class="btn btn-dark show-edit"
            >Edit</a
          >
        </div>

        <div class="row-1">
          <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
          >
            <button class="btn btn-dark show-delete mb-3">Delete</button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-8 offset-2 mb-3">
      <hr />
      <h4>Leave a Review</h4>
      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        novalidate
        class="needs-validation"
      >
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <input
            type="range"
            name="review[rating]"
            id="rating"
            min="1"
            max="5"
            class="form-range"
            
          />
        </div>
        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea
            name="review[comment]"
            id="comment"
            cols="30"
            rows="4"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">
            Please submit some comments for review 
          </div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
      </form>
    </div>
    <hr>

    <p><b>All Reviews</b></p>

   <div class="row">
      <% for( review of listing.reviews ) { %>
        <div class="card col-5 mb-3 ms-3">
          <div class="card-body">
            <div class="card-title"> <b>Jane Doe</b></div>
            <p class="card-text"> <%= review.comment %></p>
            <p class="card-text"> <%= review.rating %> stars</p>
          </div>
          
          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-2 mt-1" method="POST">
            <button class="btn btn-sm btn-dark" style="color: white;">submit</button>
          </form>
          
        </div>
      <% } %>
    </div>
    
  </div>
  <br>
</body>
